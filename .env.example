# FastAPI Configuration
APP_NAME=DogovorAI
APP_VERSION=0.1.0
APP_DESCRIPTION=Intelligent assistant for analyzing and automating legal documents
DEBUG=True

# Python
PYTHONUNBUFFERED=1

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional: Kimi API (for future integration)
HF_TOKEN=hf_your_token_here
KIMI_MODEL=moonshotai/Kimi-K2.5:fireworks-ai

# Optional: Google Vision OCR for images (required for image OCR on Vercel)
# GOOGLE_CLOUD_VISION_API_KEY=your-google-vision-api-key

# Server
HOST=0.0.0.0
PORT=8000

# Optional: Email / SMTP settings (alternative to Supabase Auth)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@example.com
# EMAIL_PASSWORD=your-email-password
# EMAIL_FROM=DogovorAI <no-reply@example.com>
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/app/auth/callback

# Google reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Admin-only endpoints (/api/metrics/*, /api/auth/users)
ADMIN_EMAILS=admin@example.com

# App URL and CORS
APP_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID_PRO=price_xxxxx
STRIPE_PRICE_ID_MAX=price_xxxxx
