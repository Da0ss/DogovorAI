# ============================================================
# Переменные окружения для деплоя на Vercel
# Скопируйте эти значения в: Vercel Dashboard → Settings → Environment Variables
# ============================================================

# ── Обязательные ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# !! ВАЖНО: для Vercel используйте Supabase Transaction Pooler URL !!
# Найдите его в Supabase → Settings → Database → Connection Pooling
# Формат: postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── AI / HuggingFace ────────────────────────────────────────
HF_TOKEN=hf_your_token_here
KIMI_MODEL=moonshotai/Kimi-K2.5:fireworks-ai

# ── Приложение ───────────────────────────────────────────────
APP_NAME=DogovorAI
APP_VERSION=0.1.0
DEBUG=False
APP_URL=https://your-vercel-app.vercel.app

# ── CORS (домены через запятую) ───────────────────────────────
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.com

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-vercel-app.vercel.app/app/auth/callback

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_PRO=price_xxxxx
STRIPE_PRICE_ID_MAX=price_xxxxx

# ── Email (опционально) ───────────────────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@email.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_FROM=your@email.com

# ── Supabase Service Key (для admin-операций) ─────────────────
# SUPABASE_SERVICE_KEY=your-supabase-service-role-key
